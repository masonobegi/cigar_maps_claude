# Copy this file to .env and fill in your details
# Only needed for sending emails (node email-sender.js)

# Your Gmail address
GMAIL_USER=you@gmail.com

# Gmail App Password (NOT your regular password)
# Get it at: myaccount.google.com → Security → 2-Step Verification → App passwords
# Create one for "Mail" and paste the 16-character code here (spaces optional)
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Optional: Google Maps Places API key (free $200/mo credit from Google)
# Get it at: console.cloud.google.com → APIs → Maps JavaScript API
# If set, adds Google Maps data to the scrape (better data for big cities)
# GOOGLE_PLACES_KEY=AIza...
