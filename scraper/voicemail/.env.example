# ── Ringless voicemail (ringless.js — recommended) ──────────────────────────
# Sign up free at slybroadcast.com — includes 5 free test drops
SLYBROADCAST_EMAIL=you@gmail.com
SLYBROADCAST_PASSWORD=yourpassword

# Public URL to your recorded message (MP3 or WAV)
# Quick way to host: record on your phone → upload to Google Drive → Share
# → copy link → convert to direct link at gdirect.sian.com.au
VOICEMAIL_AUDIO_URL=https://yoursite.com/message.mp3

# Number that shows up as the "missed call" on their phone
# Use your real cell or a free Google Voice number
CALLER_ID=5035550100

# ── Live Twilio calls (drop.js — only if you want live calls instead) ────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15035550100
